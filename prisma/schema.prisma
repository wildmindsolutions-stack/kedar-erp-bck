generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  permissions Json     @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  users       User[]

  @@map("roles")
}

model User {
  id                  String         @id @default(cuid())
  name                String
  email               String         @unique
  passwordHash        String         @map("password_hash")
  roleId              String         @map("role_id")
  isActive            Boolean        @default(true) @map("is_active")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")
  role                Role           @relation(fields: [roleId], references: [id])
  salesOrders         SalesOrder[]
  payments            Payment[]
  auditLogs           AuditLog[]
  notifications       Notification[] @relation("NotificationRecipient")
  notificationsSent   Notification[] @relation("NotificationActor")

  @@map("users")
}

model ProductCategory {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now()) @map("created_at")
  products  Product[]

  @@map("product_categories")
}

model Unit {
  id        String    @id @default(cuid())
  name      String    @unique
  symbol    String
  createdAt DateTime  @default(now()) @map("created_at")
  products  Product[]

  @@map("units")
}

model Product {
  id                String             @id @default(cuid())
  name              String
  categoryId        String             @map("category_id")
  unitId            String             @map("unit_id")
  price             Decimal            @db.Decimal(12, 2)
  hsnCode           String             @map("hsn_code")
  gstRate           Decimal            @default(5) @map("gst_rate") @db.Decimal(5, 2)
  imageUrl          String?            @map("image_url")
  lowStockThreshold Decimal            @default(10) @map("low_stock_threshold") @db.Decimal(12, 3)
  isActive          Boolean            @default(true) @map("is_active")
  isDeleted         Boolean            @default(false) @map("is_deleted")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  category          ProductCategory    @relation(fields: [categoryId], references: [id])
  unit              Unit               @relation(fields: [unitId], references: [id])
  productionBatches ProductionBatch[]
  stockLedger       StockLedger[]
  orderItems        OrderItem[]
  invoiceItems      InvoiceItem[]

  @@map("products")
}

model Customer {
  id              String           @id @default(cuid())
  name            String
  gstin           String?
  phone           String?
  email           String?
  address         String?
  city            String?
  state           String           @default("Maharashtra")
  creditLimit     Decimal          @default(0) @map("credit_limit") @db.Decimal(12, 2)
  isActive        Boolean          @default(true) @map("is_active")
  isDeleted       Boolean          @default(false) @map("is_deleted")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  salesOrders     SalesOrder[]
  customerLedger  CustomerLedger[]
  payments        Payment[]

  @@map("customers")
}

model ProductionBatch {
  id           String   @id @default(cuid())
  productId    String   @map("product_id")
  batchNo      String   @map("batch_no")
  batchDate    DateTime @map("batch_date") @db.Date
  qtyProduced  Decimal  @map("qty_produced") @db.Decimal(12, 3)
  notes        String?
  createdBy    String?  @map("created_by")
  createdAt    DateTime @default(now()) @map("created_at")
  product      Product  @relation(fields: [productId], references: [id])

  @@map("production_batches")
}

enum StockReason {
  PRODUCTION
  SALE
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
}

model StockLedger {
  id        String      @id @default(cuid())
  productId String      @map("product_id")
  qtyChange Decimal     @map("qty_change") @db.Decimal(12, 3)
  reason    StockReason
  refId     String?     @map("ref_id")
  notes     String?
  createdBy String?     @map("created_by")
  createdAt DateTime    @default(now()) @map("created_at")
  product   Product     @relation(fields: [productId], references: [id])

  @@index([productId])
  @@map("stock_ledger")
}

enum OrderStatus {
  DRAFT
  CONFIRMED
  CANCELLED
}

model SalesOrder {
  id         String      @id @default(cuid())
  customerId String      @map("customer_id")
  status     OrderStatus @default(DRAFT)
  orderDate  DateTime    @map("order_date") @db.Date
  notes      String?
  createdBy  String?     @map("created_by")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  customer   Customer    @relation(fields: [customerId], references: [id])
  creator    User?       @relation(fields: [createdBy], references: [id])
  items      OrderItem[]
  invoice    Invoice?

  @@map("sales_orders")
}

model OrderItem {
  id        String     @id @default(cuid())
  orderId   String     @map("order_id")
  productId String     @map("product_id")
  qty       Decimal    @db.Decimal(12, 3)
  rate      Decimal    @db.Decimal(12, 2)
  order     SalesOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product    @relation(fields: [productId], references: [id])

  @@map("order_items")
}

enum InvoiceStatus {
  ISSUED
  CANCELLED
}

model Invoice {
  id            String        @id @default(cuid())
  orderId       String        @unique @map("order_id")
  invoiceNo     String        @unique @map("invoice_no")
  subtotal      Decimal       @db.Decimal(12, 2)
  cgstAmount    Decimal       @default(0) @map("cgst_amount") @db.Decimal(12, 2)
  sgstAmount    Decimal       @default(0) @map("sgst_amount") @db.Decimal(12, 2)
  igstAmount    Decimal       @default(0) @map("igst_amount") @db.Decimal(12, 2)
  gstAmount     Decimal       @map("gst_amount") @db.Decimal(12, 2)
  total         Decimal       @db.Decimal(12, 2)
  sellerGstin   String        @map("seller_gstin")
  buyerGstin    String?       @map("buyer_gstin")
  status        InvoiceStatus @default(ISSUED)
  issuedAt      DateTime      @map("issued_at")
  financialYear String        @map("financial_year")
  isDeleted     Boolean       @default(false) @map("is_deleted")
  createdAt     DateTime      @default(now()) @map("created_at")
  order         SalesOrder    @relation(fields: [orderId], references: [id])
  items         InvoiceItem[]
  deliveries    Delivery[]

  @@map("invoices")
}

model InvoiceItem {
  id         String  @id @default(cuid())
  invoiceId  String  @map("invoice_id")
  productId  String  @map("product_id")
  qty        Decimal @db.Decimal(12, 3)
  rate       Decimal @db.Decimal(12, 2)
  hsnCode    String  @map("hsn_code")
  gstRate    Decimal @map("gst_rate") @db.Decimal(5, 2)
  taxable    Decimal @db.Decimal(12, 2)
  cgst       Decimal @default(0) @db.Decimal(12, 2)
  sgst       Decimal @default(0) @db.Decimal(12, 2)
  igst       Decimal @default(0) @db.Decimal(12, 2)
  lineTotal  Decimal @map("line_total") @db.Decimal(12, 2)
  invoice    Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product    Product @relation(fields: [productId], references: [id])

  @@map("invoice_items")
}

model InvoiceSequence {
  id            String @id @default(cuid())
  financialYear String @unique @map("financial_year")
  lastNumber    Int    @default(0) @map("last_number")

  @@map("invoice_sequences")
}

enum LedgerType {
  DEBIT
  CREDIT
}

model CustomerLedger {
  id         String     @id @default(cuid())
  customerId String     @map("customer_id")
  amount     Decimal    @db.Decimal(12, 2)
  type       LedgerType
  refId      String?    @map("ref_id")
  notes      String?
  createdAt  DateTime   @default(now()) @map("created_at")
  customer   Customer   @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@map("customer_ledger")
}

enum PaymentMode {
  CASH
  UPI
  BANK_TRANSFER
  CHEQUE
}

model Payment {
  id         String      @id @default(cuid())
  customerId String      @map("customer_id")
  amount     Decimal     @db.Decimal(12, 2)
  mode       PaymentMode
  reference  String?
  receivedAt DateTime    @map("received_at")
  notes      String?
  createdBy  String?     @map("created_by")
  createdAt  DateTime    @default(now()) @map("created_at")
  customer   Customer    @relation(fields: [customerId], references: [id])
  creator    User?       @relation(fields: [createdBy], references: [id])

  @@map("payments")
}

enum DeliveryStatus {
  PENDING
  DISPATCHED
  DELIVERED
  CANCELLED
}

model Delivery {
  id           String         @id @default(cuid())
  invoiceId    String         @map("invoice_id")
  challanNo    String         @unique @map("challan_no")
  vehicle      String?
  driverName   String?        @map("driver_name")
  status       DeliveryStatus @default(PENDING)
  dispatchedAt DateTime?      @map("dispatched_at")
  deliveredAt  DateTime?      @map("delivered_at")
  notes        String?
  createdAt    DateTime       @default(now()) @map("created_at")
  invoice      Invoice        @relation(fields: [invoiceId], references: [id])

  @@map("deliveries")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  entity    String
  action    String
  before    Json?
  after     Json?
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id])

  @@map("audit_log")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String
  module    String
  title     String
  message   String
  refId     String?  @map("ref_id")
  link      String?
  isRead    Boolean  @default(false) @map("is_read")
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  recipient User     @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  actor     User?    @relation("NotificationActor", fields: [createdBy], references: [id])

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}
